{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Authenticator",
  "version": "0.1.1",
  "identifier": "com.authenticator.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Authenticator",
        "width": 420,
        "height": 720,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 500,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Authenticator",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
